# ── SuperPlane (Cloud) ──
# Service-account token: Org Settings → Service accounts → Generate (shown once)
SUPERPLANE_URL=https://app.superplane.com
SUPERPLANE_TOKEN=
SUPERPLANE_ORG_NAME=

# ── GitHub ──
GITHUB_FORK_URL=                 # e.g. https://github.com/<you>/superplane
GITHUB_REPO=                     # e.g. <you>/superplane
GH_PAT=                          # fine-grained PAT: Contents + PR read/write on the fork
DEFAULT_BASE_BRANCH=main

# ── Anthropic (coding agent on the runner) ──
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# ── Render ──
RENDER_API_KEY=
RENDER_PREVIEW_SERVICE_ID=       # the single static-site service the runner redeploys per run

# ── Slack (optional) ──
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=

# ── Companion services (set after Render deploy) ──
INGEST_GATEWAY_URL=
VERIFIER_URL=
